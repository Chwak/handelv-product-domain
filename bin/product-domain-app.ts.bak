#!/usr/bin/env node
import "source-map-support/register";
import * as cdk from "aws-cdk-lib";
import { ProductDomainStack } from "../lib/product-domain-stack";
import { ProductDomainPipelineStack } from "../lib/product-domain-pipeline-stack";

const app = new cdk.App();

const environment = app.node.tryGetContext("environment") ?? "dev";
const regionCode = app.node.tryGetContext("regionCode") ?? "use1";

new ProductDomainStack(app, `${environment}-${regionCode}-hand-made-product-domain-stack`, {
  env: {
    account: process.env.CDK_DEFAULT_ACCOUNT,
    region: process.env.CDK_DEFAULT_REGION ?? "us-east-1",
  },
  environment,
  regionCode,
});

// Domain-scoped pipeline infrastructure
const managementAccountId = "567608120268";
const devAccountId = "741429964649";
const mimicProdAccountId = "329177708881";
const prodAccountId = "021657748325";
const githubConnectionArn = "arn:aws:codeconnections:us-east-1:567608120268:connection/6b01e09c-3e85-4c07-8ca7-e4313f3f1a45";

new ProductDomainPipelineStack(
  app,
  "ProductDomainPipelineStack",
  {
    env: { account: managementAccountId, region: "us-east-1" },
    domain: "product-domain",
    managementAccountId,
    devAccountId,
    mimicProdAccountId,
    prodAccountId,
    githubConnectionArn,
    description: "Domain-scoped pipeline for product-domain",
  }
);

app.synth();
